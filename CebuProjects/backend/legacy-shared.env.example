# Cebu legacy backend — shared platform middleware (SP02).
# Copy to .env only for local legacy联调; Core remains the write target for new features.

APP_NAME=ProcurePing Backend (Legacy / Shared Infra)
APP_ENV=development
DEBUG=true

DATABASE_URL=postgresql+asyncpg://cebu_app:cebu_legacy_dev@postgres:5432/cebu
JWT_SECRET=cebu-legacy-dev-only-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8100

UPLOAD_STORAGE=local
UPLOAD_DIR=./uploads
PUBLIC_FILE_BASE_URL=http://localhost:8100/static/uploads

EMAIL_ENABLED=false
TELEGRAM_ENABLED=false
ESCROW_PROVIDER=SIMULATED
ESCROW_AUTO_CAPTURE=true
