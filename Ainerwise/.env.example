# Frontend
NUXT_PUBLIC_API_BASE=http://localhost:8000/api/v1

# Telegram (Phase 5)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# AI Orchestrator
