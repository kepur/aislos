REFRESH_TOKEN_EXPIRE_DAYS=7
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:4097","http://localhost:4098","http://localhost:4099","http://127.0.0.1:4097","http://127.0.0.1:4098","http://127.0.0.1:4099","http://localhost:8000","http://localhost"]
